<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Dark Mode. -->
    <style name="Base.Theme.EventManagementApp" parent="Theme.Material3.Light.NoActionBar">
        <!-- Main theme colors -->
        <item name="colorPrimary">@color/primary_dark_pastel</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_pastel</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/bg_light</item>
        <item name="colorOnSurface">@color/black</item>

        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/primary_dark_pastel</item>

        <!-- Default style for TextInputLayout -->
        <item name="textInputStyle">@style/Widget.Material3.TextInputLayout.OutlinedBox</item>
    </style>
</resources>
